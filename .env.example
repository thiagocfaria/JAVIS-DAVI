# Aprovação
JARVIS_APPROVAL_MODE=voice_and_key
JARVIS_APPROVAL_VOICE_PASSPHRASE="Eu Sou"
JARVIS_APPROVAL_KEY_PASSPHRASE="220410"

# Allowlist de apps
JARVIS_ALLOWED_APPS=
JARVIS_ALLOW_OPEN_APP=true
JARVIS_STOP_FILE_PATH=~/.jarvis/STOP

# STT (local)
JARVIS_STT_MODE=local
# STT streaming (opcional, RealtimeSTT)
JARVIS_STT_STREAMING=0
JARVIS_STT_STREAMING_BACKEND=realtimestt
# Modelo separado para parciais (opcional). Ex: tiny/base/small
JARVIS_STT_REALTIME_MODEL=
JARVIS_STT_MIN_GAP_SECONDS=0
JARVIS_STT_ALLOWED_LATENCY_MS=0
JARVIS_STT_NORMALIZE_AUDIO=0
JARVIS_STT_NORMALIZE_TARGET=0.98
JARVIS_STT_NORMALIZE_MAX_GAIN=4.0
JARVIS_WHISPER_VAD_FILTER=0
JARVIS_STT_BEAM_SIZE=
JARVIS_STT_BEST_OF=
JARVIS_STT_TEMPERATURE=
JARVIS_STT_INITIAL_PROMPT=
JARVIS_STT_SUPPRESS_TOKENS=
JARVIS_STT_WARMUP=0
JARVIS_STT_WARMUP_SECONDS=0.5
JARVIS_STT_EARLY_TRANSCRIBE_ON_SILENCE=0
JARVIS_STT_MAX_BUFFER_SECONDS=0

# VAD (fim de fala / buffers)
# JARVIS_VAD_STRATEGY=webrtc|silero|whisper|realtimestt
JARVIS_VAD_SILENCE_MS=800
JARVIS_VAD_PRE_ROLL_MS=200
JARVIS_VAD_POST_ROLL_MS=200
JARVIS_VAD_MAX_SECONDS=30

# Silero deactivity (opcional - fim de fala mais robusto)
JARVIS_SILERO_DEACTIVITY=0
JARVIS_SILERO_SENSITIVITY=0.6
JARVIS_SILERO_USE_ONNX=0
JARVIS_SILERO_AUTO_DOWNLOAD=0

# Wake word (audio)
JARVIS_WAKE_WORD_AUDIO=0
JARVIS_WAKE_WORD_AUDIO_BACKEND=pvporcupine
JARVIS_PORCUPINE_ACCESS_KEY=
JARVIS_PORCUPINE_KEYWORD_PATH=
JARVIS_PORCUPINE_SENSITIVITY=
JARVIS_OPENWAKEWORD_MODEL_PATHS=
JARVIS_OPENWAKEWORD_INFERENCE_FRAMEWORK=onnx
JARVIS_OPENWAKEWORD_SENSITIVITY=0.5
JARVIS_OPENWAKEWORD_AUTO_DOWNLOAD=0

# Voz (limite maximo de gravacao)
# Default: 30s (min 3s, max 120s)
JARVIS_VOICE_MAX_SECONDS=30
# Default: 12s (min 5s, max 60s)
JARVIS_VOICE_ENROLL_MAX_SECONDS=12

# AEC (echo) simples - usa referencia de playback do TTS
# Valores: none | simple
JARVIS_AEC_BACKEND=none
JARVIS_AEC_REF_SECONDS=5
JARVIS_AEC_MAX_GAIN=1.0

# TTS (saida de voz)
# Modo: local | none
JARVIS_TTS_MODE=local
#
# Para manter a voz sempre humanizada (Piper), sem cair para voz robotica (espeak-ng):
# - Coloque o modelo local em: `storage/models/piper/`
# - Ex: `storage/models/piper/pt_BR-faber-medium.onnx` + `.onnx.json`
# - Depois habilite:
# JARVIS_TTS_ENGINE=piper
# JARVIS_TTS_ENGINE_STRICT=1
# JARVIS_PIPER_MODELS_DIR=storage/models/piper
# JARVIS_PIPER_VOICE=pt_BR-faber-medium
# JARVIS_PIPER_BACKEND=python
# Sugestao "CPU-safe" (da folga para o resto do Jarvis):
# JARVIS_PIPER_INTRA_OP_THREADS=1
# JARVIS_PIPER_INTER_OP_THREADS=1
#
# Otimizacoes de latencia percebida (recomendado com Piper):
# JARVIS_TTS_STREAMING=1
# JARVIS_TTS_STREAM_CHUNK_BYTES=4096
# JARVIS_TTS_CACHE=1
# JARVIS_TTS_WARMUP=1
# JARVIS_TTS_WARMUP_BLOCKING=1
#
# Modo hibrido (sem voz robotica): um beep rapido enquanto o Piper "pensa"
# JARVIS_TTS_ACK_EARCON=1
# JARVIS_TTS_ACK_TIMEOUT_MS=250
#
# Opcional: ack falado (humanizado) em vez de beep
# JARVIS_TTS_ACK_PHRASE="Entendi. Já vou responder."
#
# PRIORIDADE 2 (latencia percebida no modo --voice)
# Fase 1 (ack imediato): toca um beep/frase curta assim que a fala "estabiliza"
# (nao usa voz robotica / espeak).
# JARVIS_VOICE_PHASE1=1
#
# Overlap (experimental): prefetch do plano usando parciais do STT (RealtimeSTT).
# Por padrao fica desligado para nao disputar CPU.
# JARVIS_VOICE_OVERLAP_PLAN=1
# JARVIS_VOICE_OVERLAP_STABLE_MS=350
# JARVIS_VOICE_OVERLAP_MIN_CHARS=12

# ----------------------------
# PERFIL RECOMENDADO (PRODUCAO / CPU-SAFE)
# Objetivo: voz humanizada (Piper) + baixa latencia + deixar folga de CPU pro resto do Jarvis.
#
# Auto-config: no modo `--voice` / `--voice-loop`, o Jarvis tenta aplicar este perfil
# automaticamente quando `JARVIS_AUTO_CONFIGURE=1` (padrao). Para desligar:
# JARVIS_AUTO_CONFIGURE=0
#
# Auto-relocate: se o seu `.env` tiver paths hardcoded que nao existem/nao tem permissao
# (ex.: `/home/u/.jarvis/...`), o Jarvis tenta mover automaticamente para `JARVIS_DATA_DIR`.
# Para desligar:
# JARVIS_AUTO_RELOCATE_PATHS=0
#
# JARVIS_DEBUG=0
# JARVIS_TTS_MODE=local
# JARVIS_TTS_ENGINE=piper
# JARVIS_TTS_ENGINE_STRICT=1
# JARVIS_PIPER_MODELS_DIR=storage/models/piper
# JARVIS_PIPER_VOICE=pt_BR-faber-medium
# JARVIS_PIPER_BACKEND=python
# JARVIS_PIPER_INTRA_OP_THREADS=1
# JARVIS_PIPER_INTER_OP_THREADS=1
# JARVIS_TTS_STREAMING=1
# JARVIS_TTS_CACHE=1
# JARVIS_TTS_WARMUP=1
# JARVIS_TTS_WARMUP_BLOCKING=1
#
# Latencia percebida (sem voz robotica):
# JARVIS_VOICE_PHASE1=1
# JARVIS_TTS_ACK_PHRASE="Entendi. Já vou responder."
# JARVIS_TTS_ACK_PHRASE_WARMUP_BLOCKING=1
#
# Manter overlap desligado por padrao (evita disputar CPU com STT/LLM):
# JARVIS_VOICE_OVERLAP_PLAN=0

# Cerebro local (OpenAI-compat)
JARVIS_LOCAL_LLM_BASE_URL=
JARVIS_LOCAL_LLM_API_KEY=
JARVIS_LOCAL_LLM_MODEL=qwen2.5-7b-instruct
JARVIS_LOCAL_LLM_TIMEOUT_S=30
JARVIS_LOCAL_LLM_COOLDOWN_S=300

# Agent S3 (GUI)
JARVIS_S3_WORKER_ENGINE_TYPE=openai_compat
JARVIS_S3_WORKER_BASE_URL=
JARVIS_S3_WORKER_API_KEY=
JARVIS_S3_WORKER_MODEL=qwen2.5-7b-instruct
JARVIS_S3_GROUNDING_ENGINE_TYPE=openai_compat
JARVIS_S3_GROUNDING_BASE_URL=
JARVIS_S3_GROUNDING_API_KEY=
JARVIS_S3_GROUNDING_MODEL=ui-tars-1.5-7b
JARVIS_S3_GROUNDING_WIDTH=1920
JARVIS_S3_GROUNDING_HEIGHT=1080
JARVIS_S3_MAX_STEPS=15
JARVIS_S3_MAX_TRAJECTORY=8
JARVIS_S3_ENABLE_REFLECTION=true
JARVIS_S3_ENABLE_CODE_AGENT=true
JARVIS_S3_CODE_AGENT_BUDGET=20
JARVIS_S3_CODE_WORKDIR=
JARVIS_S3_MAX_IMAGE_DIM=1920

# Browser AI (manual) e auto-aprendizado
JARVIS_BROWSER_AI_ENABLED=true
JARVIS_BROWSER_AI_URL=https://chatgpt.com
JARVIS_AUTO_LEARN_PROCEDURES=true
JARVIS_BLOCK_EXTERNAL_SENSITIVE=true
JARVIS_EXTERNAL_ASK_ON_SENSITIVE=true
JARVIS_SENSITIVE_KEYWORDS_STRICT=false

# Livro de procedimentos (SQLite)
JARVIS_PROCEDURES_PATH=~/.jarvis/procedures.db
JARVIS_PROCEDURES_MAX_TOTAL=300
JARVIS_PROCEDURES_MAX_PER_TAG=20
JARVIS_PROCEDURES_TTL_DAYS=90

# Memória remota (VPS/local HTTP)
JARVIS_REMOTE_MEMORY_URL=
JARVIS_REMOTE_MEMORY_TOKEN=

# Chat local (status/explicacoes)
JARVIS_CHAT_LOG_PATH=~/.jarvis/chat.log
JARVIS_CHAT_INBOX_PATH=~/.jarvis/chat_inbox.txt
JARVIS_CHAT_AUTO_OPEN=true
JARVIS_CHAT_OPEN_COMMAND=
JARVIS_CHAT_OPEN_COOLDOWN_S=5
YDTOOL_SOCKET=/tmp/.ydotool_socket

# OCR cache (Python validator)
JARVIS_OCR_CACHE_SIZE=4

# Embeddings (memoria vetorial, local)
JARVIS_ENABLE_EMBEDDINGS=true
JARVIS_EMBED_PROVIDER=local
JARVIS_EMBED_MODEL=intfloat/multilingual-e5-small
JARVIS_EMBED_DIM=384
JARVIS_EMBED_EPISODES=false
