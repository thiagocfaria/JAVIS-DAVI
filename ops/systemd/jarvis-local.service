[Unit]
Description=Jarvis Local Agent
After=network.target sound.target

[Service]
Type=simple
User=jarvis
WorkingDirectory=/opt/jarvis
EnvironmentFile=/etc/jarvis/jarvis-local.env
ExecStart=/usr/bin/python3 -m jarvis.app --voice-loop
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
